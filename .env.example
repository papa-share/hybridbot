# Copier vers .env

ENV=development
DEBUG=1

# Sans historique (défaut local)
AUTH_MODE=none
AUTH_PASSWORD=
CHAINLIT_AUTH_SECRET=

# Avec historique : décommenter le bloc ci-dessous + make db-init + make user-create
# AUTH_MODE=password
# CHAINLIT_AUTH_SECRET=   # uv run python -m chainlit create-secret
# DATABASE_URL=postgresql+asyncpg://chainlit:chainlit@localhost:5432/chainlit
#
# Admin : make user-list | user-disable | user-enable | user-reset-pass | user-set-role
#
# Dev sans PostgreSQL (mot de passe unique partagé) :
# AUTH_MODE=password
# AUTH_PASSWORD=change-moi

MAX_IMAGE_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=50
MAX_FILES=5

# PDF : Java 11+ requis (opendataloader-pdf, installé via make install-dev)

OLLAMA_TIMEOUT=120
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=gpt-oss:120b-cloud
DEFAULT_WEB_MODEL=gpt-oss:120b-cloud

# Recherche web (Exa), https://dashboard.exa.ai/api-keys
EXA_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Optionnel : modèles et génération (défauts dans config.py)
# DEFAULT_TEMPERATURE=0.4
# DEFAULT_TOP_P=0.9
# DEFAULT_MAX_TOKENS=1024
# DEFAULT_NUM_CTX=8192
# WEB_SEARCH_NUM_CTX=32768
# MAX_CONTEXT_MESSAGES=20
# SYSTEM_PROMPT=Réponds en français, court et factuel.
# VISION_MODELS=
# WEB_SEARCH_MODELS=
