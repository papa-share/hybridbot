# Copier vers .env

ENV=development
DEBUG=1

AUTH_MODE=none
AUTH_PASSWORD=
CHAINLIT_AUTH_SECRET=

PERSISTENCE=none
DB_PATH=./chainlit.db

MAX_IMAGE_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=2
MAX_FILES=5

OLLAMA_TIMEOUT=120
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=gpt-oss:120b-cloud
DEFAULT_WEB_MODEL=gpt-oss:120b-cloud

# Recherche web (Exa), https://dashboard.exa.ai/api-keys
EXA_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
