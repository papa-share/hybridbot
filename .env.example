# Configuration de l'Assistant IA Hybride
# Copiez ce fichier vers .env et ajustez selon vos besoins

# ==================== AUTHENTIFICATION ====================
# Mode d'authentification : "none" (sans login) ou "password" (avec login)
AUTH_MODE=none

# Secret pour JWT (obligatoire si AUTH_MODE=password)
# Générer avec : chainlit create-secret
CHAINLIT_AUTH_SECRET=

# ==================== PERSISTANCE ====================
# Sauvegarde des conversations : "none" (désactivée) ou "local" (SQLite)
PERSISTENCE=none

# ==================== MODE DEBUG ====================
# Activer les logs détaillés : 1 (activé) ou 0 (désactivé)
DEBUG=1

# ==================== CONFIGURATION AVANCÉE ====================
# Environnement d'exécution : "development" ou "production"
ENV=development

# Limites de taille pour les uploads (optionnel)
# Valeurs par défaut définies dans config.py
MAX_IMAGE_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=2
MAX_FILES=5

# Timeout pour les requêtes Ollama (en secondes)
OLLAMA_TIMEOUT=180

# URL du serveur Ollama (modifier si serveur distant)
OLLAMA_URL=http://localhost:11434

# Modèle par défaut (optionnel)
# DEFAULT_MODEL=gpt-oss:120b-cloud
