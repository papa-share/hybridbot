# Configuration pour l'environnement de PRODUCTION
# Ce fichier doit être copié vers .env lors du déploiement en production

# ==================== ENVIRONNEMENT ====================
# Mode production (désactive le mode debug)
ENV=production
DEBUG=0

# ==================== AUTHENTIFICATION ====================
# OBLIGATOIRE en production pour la sécurité
AUTH_MODE=password

# Secret pour JWT (DOIT être généré et défini)
# Générer avec: chainlit create-secret
# IMPORTANT: Remplacer cette valeur par votre propre secret en production
CHAINLIT_AUTH_SECRET=<GENERER_AVEC_chainlit_create-secret>

# ==================== PERSISTANCE ====================
# Activer la sauvegarde locale des conversations
PERSISTENCE=local

# ==================== LIMITES DE FICHIERS ====================
# Limites plus strictes en production
MAX_IMAGE_SIZE_MB=20
MAX_DOCUMENT_SIZE_MB=2
MAX_FILES=3

# ==================== OLLAMA ====================
# Timeout pour les requêtes Ollama (en secondes)
OLLAMA_TIMEOUT=180

# URL du serveur Ollama
# Modifier si Ollama est déployé sur un serveur distant
OLLAMA_URL=http://localhost:11434

# ==================== MODÈLES ====================
# Modèle par défaut à utiliser
DEFAULT_MODEL=gpt-oss:120b-cloud

# ==================== RECHERCHE WEB ====================
# Clé API Ollama pour la recherche web en temps réel
# Obtenir une clé sur: https://ollama.com/settings/keys
# IMPORTANT: Remplacer par votre clé API en production
OLLAMA_API_KEY=<OBTENIR_SUR_https://ollama.com/settings/keys>

# Activer/désactiver la recherche web automatique
WEB_SEARCH_ENABLED=1

# Nombre max de résultats web à retourner
WEB_SEARCH_MAX_RESULTS=5

# Mode de recherche: "auto" (détection automatique) ou "tool" (tool calling)
WEB_SEARCH_MODE=auto

# ==================== CACHE SYSTÈME ====================
# Activer le cache pour optimiser la latence (-30% à -50%)
CACHE_ENABLED=1

# Durée de vie du cache en secondes (1800 = 30 minutes)
CACHE_TTL=1800

# Nombre maximum d'entrées en cache
CACHE_MAX_SIZE=100

# ==================== GÉNÉRATION D'IMAGES ====================
# Activer la génération d'images (auto = détection macOS)
# Valeurs possibles: auto, 1 (forcé), 0 (désactivé)
IMAGE_GENERATION_ENABLED=auto

# Répertoire de sortie pour les images générées
IMAGE_OUTPUT_DIR=./generated_images

# ==================== NOTES ====================
# Avant de déployer en production:
# 1. Générer un secret JWT: chainlit create-secret
# 2. Remplacer <GENERER_AVEC_chainlit_create-secret> avec la valeur générée
# 3. Vérifier que Ollama est installé et démarré
# 4. Copier ce fichier vers .env: cp .env.production .env
# 5. Installer les dépendances: pip install -r requirements.txt
# 6. Redémarrer l'application
