# Copier vers .env en prod (équipe, PostgreSQL obligatoire)

ENV=production
DEBUG=0

AUTH_MODE=password
CHAINLIT_AUTH_SECRET=   # uv run python -m chainlit create-secret

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/chainlit

# Comptes : make db-init puis make user-create USER=admin PASS=... ROLE=admin
# Admin CLI : make user-list | user-disable | user-enable | user-reset-pass | user-set-role

MAX_IMAGE_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=2
MAX_FILES=5

OLLAMA_TIMEOUT=180
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=gpt-oss:120b-cloud
DEFAULT_WEB_MODEL=gpt-oss:120b-cloud

EXA_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
