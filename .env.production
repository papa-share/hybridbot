# Copier vers .env en prod

ENV=production
DEBUG=0

AUTH_MODE=password
AUTH_PASSWORD=change-moi
CHAINLIT_AUTH_SECRET=<chainlit create-secret>

PERSISTENCE=local
DB_PATH=./chainlit.db

MAX_IMAGE_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=2
MAX_FILES=5

OLLAMA_TIMEOUT=180
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=gpt-oss:120b-cloud
DEFAULT_WEB_MODEL=gpt-oss:120b-cloud

EXA_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
